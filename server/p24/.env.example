# Skopiuj do .env lokalnie (nie commituj). Na Railway / Render ustaw te same zmienne w panelu.

# Z panelu Przelewy24: Moje konto → Dane do integracji (sandbox vs produkcja)
P24_MERCHANT_ID=123456
P24_POS_ID=123456
P24_CRC_KEY=twoj_crc_z_panelu

# true = sandbox.przelewy24.pl, false = secure.przelewy24.pl (produkcja)
P24_SANDBOX=true

# Publiczny URL tego serwera (bez końcowego /) — musi być HTTPS w produkcji
PUBLIC_BASE_URL=https://twoj-projekt.up.railway.app

# Strona statyczna (FTP / GitHub Pages) — skąd user wraca po płatności
FRONTEND_URL=https://relationshipscan.app

# Kwota w groszach (19,00 zł = 1900)
P24_AMOUNT_GROSZE=1900

PORT=3000
